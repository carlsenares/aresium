# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://aresium:aresium@localhost:5432/aresium?schema=public"

# --- Groq (free LLM API) for smart categorisation — https://console.groq.com ---
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# --- Optional alternative LLM provider ---
ANTHROPIC_API_KEY=""

# --- Telegram reminder bot (npm run remind) ---
# Create a bot with @BotFather to get the token; TELEGRAM_CHAT_ID is your numeric user id.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
# Optional overrides for the links in the reminder:
# ARESIUM_BANK_URL="https://www.eu-banking.de"
# ARESIUM_PAYPAL_URL="https://www.paypal.com"
