{
  "name": "aresium",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal finance tracker for VR Bank + PayPal (CSV/CAMT import)",
  "scripts": {
    "db:up": "docker compose up -d db",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed": "tsx scripts/seed-categories.ts",
    "reset:data": "tsx scripts/reset-data.ts",
    "import": "tsx src/import/run.ts",
    "categorize": "tsx scripts/categorize.ts",
    "summary": "tsx scripts/summary.ts",
    "uncat": "tsx scripts/uncategorised.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
