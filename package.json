    "reset:data": "tsx scripts/reset-data.ts",
    "import": "tsx src/import/run.ts",
    "backfill:balance": "tsx scripts/backfill-balance.ts",
    "categorize": "tsx scripts/categorize.ts",
    "data:check": "tsx scripts/data-check.ts",
    "enrich": "tsx src/enrich/run.ts",
    "places": "tsx scripts/places.ts",
    "ai": "tsx scripts/ai.ts",
    "web": "tsx src/web/server.ts",
    "remind": "tsx src/bot/remind.ts",
    "recat": "tsx scripts/recat.ts",
    "summary": "tsx scripts/summary.ts",
    "show": "tsx scripts/show.ts",
    "uncat": "tsx scripts/uncategorised.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
