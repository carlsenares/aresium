{
  "name": "aresium",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal finance tracker for VR Bank + PayPal (CSV/CAMT import)",
  "scripts": {
    "db:up": "docker compose up -d db",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
